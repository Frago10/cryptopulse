# =============================================================================
# CryptoPulse — Variables de entorno
# Copia este archivo a `.env` y ajusta los valores.
# NUNCA subas .env al repositorio (ya está en .gitignore).
# =============================================================================

# ---- Postgres (warehouse) ----
POSTGRES_USER=cryptopulse
POSTGRES_PASSWORD=changeme_in_prod
POSTGRES_DB=cryptopulse

# ---- MinIO (data lake bronze/silver/gold) ----
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio12345
MINIO_ENDPOINT=http://localhost:9000
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold

# ---- Airflow ----
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=ZmDfcTF7_60GrrY167zsiPd67pEvs0aGOv2oasOM1Pg=

# ---- APIs externas ----
# CoinGecko no requiere key para el tier gratuito
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Binance WebSocket (público, sin key)
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Reddit — crea una app en https://www.reddit.com/prefs/apps (script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cryptopulse/0.1 by your_username

# Fear & Greed Index (público, sin key)
FNG_API_URL=https://api.alternative.me/fng/

# ---- Telegram bot (Fase 10) ----
# Crea un bot con @BotFather y consigue tu chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Kafka / Redpanda ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TICKS=ticks

# ---- Símbolos a rastrear (coma-separados, sin espacios) ----
TRACKED_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,ADAUSDT,XRPUSDT,DOGEUSDT,AVAXUSDT,DOTUSDT
